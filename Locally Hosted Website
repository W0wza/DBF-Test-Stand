// ════════════════════════════════════════════════════════════════════════════
//  ThrustStand.ino
//  ESP32 + SparkFun HX711 + Phidgets 10kg load cell
//
//  What this does:
//    - Creates a WiFi hotspot called "ThrustStand"
//    - Hosts a live thrust dashboard at 192.168.4.1
//    - Displays current thrust, peak thrust, and a live graph
//    - Stopwatch auto-starts when thrust exceeds 0.25 lb
//    - Logs all data as a downloadable CSV
//
//  Hardware:
//    - ESP32 Dev Module (ESP-WROOM-32)
//    - SparkFun HX711 Load Cell Amplifier (SEN-13879)
//    - Phidgets S-Type Load Cell 10kg (1305)
//
//  Wiring:
//    Load cell RED   → HX711 RED (E+)
//    Load cell BLACK → HX711 BLK (E-)
//    Load cell GREEN → HX711 GRN (A+)
//    Load cell WHITE → HX711 WHT (A-)
//    HX711 VCC → ESP32 VIN (5V)
//    HX711 VDD → ESP32 3V3
//    HX711 GND → ESP32 GND
//    HX711 DAT → ESP32 GPIO 4
//    HX711 CLK → ESP32 GPIO 5
//
//  Libraries needed (install via Arduino Library Manager):
//    - HX711 by Rob Tillaart
//    - WiFi and WebServer are built into the ESP32 core
// ════════════════════════════════════════════════════════════════════════════

#include <WiFi.h>       // built-in: creates the WiFi access point
#include <WebServer.h>  // built-in: handles HTTP requests from the browser
#include "HX711.h"      // third-party: communicates with the HX711 chip

// ── WiFi credentials ─────────────────────────────────────────────────────────
// The ESP32 broadcasts this network. Connect to it from any phone or laptop.
const char* AP_SSID = "ThrustStand";
const char* AP_PASS = "thrust1234";

// ── HX711 pin definitions ────────────────────────────────────────────────────
// These must match your physical wiring to the ESP32.
const int HX_DT  = 4;   // HX711 DAT → ESP32 GPIO 4
const int HX_SCK = 5;   // HX711 CLK → ESP32 GPIO 5

// ── Calibration constant ─────────────────────────────────────────────────────
// This is the number of raw HX711 counts that equals one pound of force.
// YOU MUST CHANGE THIS to your own calibration value.
// See Calibration.ino and CALIBRATION_GUIDE.md for how to find your number.
// Formula: counts_per_lb = (loaded_counts - zero_counts) / known_weight_lb
float counts_per_lb = 206000.0;

// ── Library objects ──────────────────────────────────────────────────────────
HX711 scale;          // talks to the HX711 amplifier
WebServer server(80); // listens for browser requests on port 80 (standard HTTP)

// ── Session timer ─────────────────────────────────────────────────────────────
// t0_ms is set at boot and again whenever Tare is pressed.
// All time values sent to the browser are (millis() - t0_ms) / 1000.
static unsigned long t0_ms = 0;

// ── Logging flag ──────────────────────────────────────────────────────────────
// When false, the ESP32 still reads the sensor but does not save to CSV.
// Toggled by the Pause button on the dashboard.
bool loggingEnabled = true;

// ── In-RAM CSV log ───────────────────────────────────────────────────────────
// All readings are appended here as "time_s,thrust_lb\n" lines.
// Trimmed automatically when it exceeds CSV_MAX_CHARS to protect RAM.
// This log is lost when the ESP32 loses power — download before unplugging.
String csvLog = "time_s,thrust_lb\n";
const size_t CSV_MAX_CHARS = 60000;  // ~3000 readings before oldest are dropped

// ── Sample struct ─────────────────────────────────────────────────────────────
// Holds one complete reading from the load cell.
struct Sample {
  float thrust_lb;      // clamped thrust shown on the graph (no tiny negatives)
  float thrust_lb_raw;  // raw unclamped value (useful for debugging)
  long  counts;         // raw integer from the HX711 before any conversion
};

// ── readSample() ──────────────────────────────────────────────────────────────
// Reads the HX711, converts counts to pounds, and returns a Sample struct.
Sample readSample() {
  // read_average(3): take 3 readings and average them.
  // More averages = less noise but slower. 3 is a good balance for 0.5s polling.
  long counts = scale.read_average(3);

  // get_offset() returns the tare zero set during setup() or when Tare is pressed
  long offset = scale.get_offset();

  // convert raw counts to pounds using the calibration constant
  float thrust_raw = (counts - offset) / counts_per_lb;

  // clamp tiny negatives caused by noise to zero so the graph looks clean at idle
  // anything below -0.20 lb is kept as-is so real negative readings are visible
  float thrust = thrust_raw;
  if (thrust < 0.0f && thrust > -0.20f) thrust = 0.0f;

  Sample s;
  s.thrust_lb     = thrust;
  s.thrust_lb_raw = thrust_raw;
  s.counts        = counts;
  return s;
}

// ── HTML dashboard ────────────────────────────────────────────────────────────
// The entire webpage (HTML + CSS + JavaScript) is stored here in flash memory.
//
// PROGMEM: stores the string in flash instead of RAM to save precious RAM.
//
// R"HTMLEND(...)HTMLEND": a C++ raw string literal. Everything between the
// delimiters is treated as plain text so HTML quotes and special characters
// do not need escaping. The word HTMLEND is just a chosen delimiter name —
// it must be the same on both ends and must not appear anywhere in the HTML.
//
// The browser polls /sample every 500ms to get a JSON reading, then updates
// the stat cards and redraws the canvas graph.
